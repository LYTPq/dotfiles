{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "gruvbox",
  "keybinds": {
    "leader": "ctrl+space",
    "app_exit": "ctrl+c,<leader>q",
    "editor_open": "<leader>e",

    "theme_list": "<leader>t",
    "sidebar_toggle": "<leader>b",
    "scrollbar_toggle": "<leader>B",
    "username_toggle": "<leader>u",
    "status_view": "<leader>s",
    "tool_details": "<leader>d",

    "session_new": "<leader>n",
    "session_list": "<leader>l",
    "session_compact": "<leader>c",
    "session_interrupt": "escape",
    "session_export": "none",
    "session_timeline": "none",
    "session_fork": "none",
    "session_rename": "none",
    "session_share": "none",
    "session_unshare": "none",
    "session_child_cycle": "<leader>right",
    "session_child_cycle_reverse": "<leader>left",
    "session_parent": "<leader>up",

    "messages_copy": "<leader>y",
    "messages_line_up": "ctrl+alt+up",
    "messages_line_down": "ctrl+alt+down",
    "messages_next": "ctrl+alt+right",
    "messages_previous": "ctrl+alt+left",
    "messages_first": "ctrl+shift+alt+up",
    "messages_last": "ctrl+shift+alt+down",

    "messages_undo": "ctrl+alt+a",
    "messages_redo": "ctrl+alt+d",

    "messages_toggle_conceal": "<leader>h",
    "messages_last_user": "none",

    "model_list": "<leader>m",
    "model_cycle_recent": "none",
    "model_cycle_recent_reverse": "none",
    "model_cycle_favorite": "none",
    "model_cycle_favorite_reverse": "none",

    "variant_cycle": "ctrl+t",
    "command_list": "ctrl+p",

    "agent_list": "<leader>a",
    "agent_cycle": "tab",
    "agent_cycle_reverse": "shift+tab",

    "input_submit": "return",
    "input_newline": "shift+return,ctrl+return,alt+return",
    "input_clear": "none",
    "input_paste": "none",

    "input_move_left": "left",
    "input_move_right": "right",

    "input_move_up": "up",
    "input_move_down": "down",

    "input_select_left": "shift+left",
    "input_select_right": "shift+right",

    "input_select_up": "shift+up",
    "input_select_down": "shift+down",

    "input_line_home": "none",
    "input_line_end": "none",

    "input_select_line_home": "none",
    "input_select_line_end": "none",

    "input_visual_line_home": "none",
    "input_visual_line_end": "none",

    "input_select_visual_line_home": "none",
    "input_select_visual_line_end": "none",

    "input_buffer_home": "none",
    "input_buffer_end": "none",

    "input_select_buffer_home": "none",
    "input_select_buffer_end": "none",

    "input_delete_line": "none",
    "input_delete_to_line_end": "none",
    "input_delete_to_line_start": "none",

    "input_backspace": "backspace",
    "input_delete": "none",

    "input_undo": "alt+a",
    "input_redo": "alt+d",

    "input_word_forward": "ctrl+right",
    "input_word_backward": "ctrl+left",

    "input_select_word_forward": "ctrl+shift+right",
    "input_select_word_backward": "ctrl+shift+left",

    "input_delete_word_forward": "none",
    "input_delete_word_backward": "ctrl+backspace",

    "history_previous": "up",
    "history_next": "down",
    "terminal_suspend": "ctrl+z",
    "terminal_title_toggle": "none",
    "tips_toggle": "<leader>h"
  },
  "scroll_speed": 1,
  "scroll_acceleration": {
    "enabled": true
  },
  "diff_style": "stacked"
}
