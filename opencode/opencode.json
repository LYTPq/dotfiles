{
  "$schema": "https://opencode.ai/config.json",
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },

  "autoupdate": true,

  "permission": {
    "read": "allow",
    "list": "allow",
    "glob": "allow",
    "grep": "allow",

    "websearch": "allow",
    "webfetch": "allow",
    "codesearch": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "edit": "ask",

    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "xargs *": "allow",
      "wc *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "du *": "allow",

      "rm *": "ask",
      "mv *": "ask",
      "cp *": "ask",

      "git *": "ask",
      "git status *": "allow",
      "git submodule status *": "allow",
      "git log *": "allow",
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "git checkout -b *": "deny",
      "git merge *": "deny",
      "git rebase *": "deny",
      "git reset *": "deny",

      "gh *": "ask",
      "gh browse *": "allow",
      "gh issue list *": "allow",
      "gh issue status *": "allow",
      "gh issue view *": "allow",
      "gh pr list * ": "allow",
      "gh pr status * ": "allow",
      "gh pr diff * ": "allow",
      "gh pr view * ": "allow"
    }
  }
}
