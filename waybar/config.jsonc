      // "2": "ΎΞψ",
      // "3": "ΎΑφ",
      // "4": "ΎΑΒ",
      // "5": "≤░Σ┤",
      // "6": "ΌηΧ",
      // "7": "≤░Ξδ",
      // "8": "ΌγΡ",
      // "9": "≤░Ξ╣",
      // "10": "≤░φ┤",
      // "special": "Όμξ"
